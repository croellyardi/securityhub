function showSubTab(id,el,parentId){
  const parent=document.getElementById(parentId);
  parent.querySelectorAll('[id^="'+parentId.replace('u','u')+'"]').forEach(()=>{});
  // find sibling sub-content divs
  const atabs=el.closest('.access-subtabs');
  const allIds=Array.from(atabs.querySelectorAll('.atab')).map((_,i)=>i===0?parentId+'Access':parentId+'NoAccess');
  allIds.forEach(sid=>{const el2=document.getElementById(sid);if(el2)el2.style.display='none';});
