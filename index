<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Security Hub</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
body{background:#f4f4f4;min-height:100vh;font-size:13px}
.topnav{background:#1e2a3b;height:44px;display:flex;align-items:center;padding:0 12px;gap:4px;color:#c8d0dc;font-size:13px;position:fixed;top:0;left:0;right:0;z-index:100}
.topnav .logo{display:flex;align-items:center;gap:8px;color:#fff;font-weight:600;font-size:14px;margin-right:12px}
.nav-item{padding:4px 10px;border-radius:4px;cursor:pointer;color:#c8d0dc;font-size:13px;display:flex;align-items:center;gap:4px}
.nav-item:hover,.nav-item.active{background:#2d3f55;color:#fff}
.nav-arrow{font-size:9px;opacity:.7}
.topnav-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.avatar{width:28px;height:28px;border-radius:50%;background:#4a7fcb;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600}
.topnav-icon{color:#c8d0dc;font-size:16px;cursor:pointer;padding:4px}
.sidebar{width:40px;background:#fff;border-right:0.5px solid #e0e0e0;position:fixed;left:0;top:44px;bottom:0;display:flex;flex-direction:column;align-items:center;padding:10px 0;gap:8px;z-index:90}
.sidebar-icon{width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#6b7280}
.sidebar-icon:hover{background:#f3f4f6}
.sidebar-icon.active{background:#e8f0fd;color:#2563eb}
.main{margin-left:40px;margin-top:44px}
.page-header{background:#fff;border-bottom:0.5px solid #e0e0e0;padding:18px 24px 0;position:sticky;top:44px;z-index:80}
.header-row{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.shield-icon{width:36px;height:36px;background:#e8f0fd;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.page-title{font-size:20px;font-weight:600;color:#111}
.page-sub{font-size:13px;color:#6b7280;margin-top:1px}
.tabs{display:flex}
.tab{padding:10px 16px;font-size:13px;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;display:flex;align-items:center;gap:6px;white-space:nowrap}
.tab:hover{color:#374151}
.tab.active{color:#2563eb;border-bottom:2px solid #2563eb;font-weight:500}
.content{padding:20px 24px;min-height:calc(100vh - 160px)}
.toolbar{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.search-wrap{position:relative}
.search-wrap input{padding:6px 10px 6px 30px;border:0.5px solid #d1d5db;border-radius:6px;font-size:13px;width:180px;background:#fff;color:#111;outline:none}
.search-wrap input:focus{border-color:#2563eb}
.search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px}
.count-badge{background:#2563eb;color:#fff;border-radius:5px;padding:2px 8px;font-size:12px;font-weight:600;flex-shrink:0}
.toolbar-label{font-size:14px;color:#374151;font-weight:500}
.ml-auto{margin-left:auto}
.btn-primary{background:#2563eb;color:#fff;border:none;border-radius:6px;padding:7px 14px;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap}
.btn-primary:hover{background:#1d4ed8}
.btn-more{background:#fff;border:0.5px solid #d1d5db;border-radius:6px;padding:6px 10px;cursor:pointer;color:#374151;font-size:16px}
.btn-more:hover{background:#f3f4f6}
.filter-select{border:0.5px solid #d1d5db;border-radius:6px;padding:6px 10px;font-size:13px;background:#fff;color:#374151;cursor:pointer;outline:none}
.table-wrap{background:#fff;border:0.5px solid #e0e0e0;border-radius:8px;overflow:hidden}
table{width:100%;border-collapse:collapse;font-size:13px}
thead tr{border-bottom:0.5px solid #e5e7eb;background:#fff}
th{padding:10px 12px;text-align:left;color:#6b7280;font-weight:500;font-size:12px;white-space:nowrap;user-select:none;cursor:pointer}
th:hover{color:#374151}
.sort-icon{font-size:10px;opacity:.6;margin-left:2px}
tbody tr{border-bottom:0.5px solid #f3f4f6}
tbody tr:hover{background:#f9fafb;cursor:pointer}
tbody tr:last-child{border-bottom:none}
td{padding:10px 12px;color:#374151;vertical-align:top}
.td-link{color:#2563eb;cursor:pointer;font-weight:500;display:flex;align-items:center;gap:6px}
.access-lines{line-height:1.7;color:#374151}
.no-access{color:#9ca3af}
.status-pill{display:inline-block;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:500}
.status-active{background:#d1fae5;color:#065f46}
.status-inactive{background:#f3f4f6;color:#6b7280}
.status-locked{background:#fef3c7;color:#92400e}
.report-type{display:inline-block;border-radius:4px;padding:2px 7px;font-size:11px;font-weight:700}
.type-sql{background:#dbeafe;color:#1d4ed8}
.type-ysr{background:#fef3c7;color:#92400e}
.roles-badge{display:inline-flex;align-items:center;justify-content:center;background:#16a34a;color:#fff;border-radius:5px;min-width:28px;height:22px;font-size:12px;font-weight:700;padding:0 7px}
.cb{width:14px;height:14px;cursor:pointer;accent-color:#2563eb}

/* DRAWER */
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.25);z-index:200;display:none}
.drawer-overlay.open{display:block}
.drawer{position:fixed;top:0;right:0;bottom:0;width:790px;background:#fff;box-shadow:-4px 0 20px rgba(0,0,0,.12);z-index:201;display:flex;flex-direction:column;overflow:hidden;transform:translateX(100%);transition:transform .2s ease}
.drawer.open{transform:translateX(0)}
.drawer-header{padding:16px 20px 0;border-bottom:0.5px solid #e5e7eb;flex-shrink:0}
.drawer-title-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.drawer-avatar-circle{width:36px;height:36px;border-radius:50%;background:#f59e0b;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:700;flex-shrink:0}
.drawer-shield{width:32px;height:32px;background:#e8f0fd;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.drawer-title{font-size:16px;font-weight:600;color:#111}
.drawer-sub{font-size:12px;color:#6b7280}
.drawer-close{margin-left:auto;background:none;border:none;font-size:20px;color:#6b7280;cursor:pointer;padding:4px 8px;line-height:1}
.drawer-close:hover{color:#111}
.drawer-tabs{display:flex;overflow-x:auto;gap:0}
.drawer-tabs::-webkit-scrollbar{height:3px}
.drawer-tabs::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:2px}
.dtab{padding:8px 14px;font-size:12px;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;flex-shrink:0}
.dtab:hover{color:#374151}
.dtab.active{color:#2563eb;border-bottom:2px solid #2563eb;font-weight:500}
.drawer-body{flex:1;overflow-y:auto;padding:20px}
.drawer-footer{padding:12px 20px;border-top:0.5px solid #e5e7eb;display:flex;justify-content:flex-end;gap:8px;flex-shrink:0}
.btn-cancel{background:#fff;border:0.5px solid #d1d5db;border-radius:6px;padding:7px 16px;font-size:13px;cursor:pointer;color:#374151}
.btn-cancel:hover{background:#f3f4f6}
.btn-save{background:#2563eb;color:#fff;border:none;border-radius:6px;padding:7px 18px;font-size:13px;font-weight:500;cursor:pointer}
.btn-save:hover{background:#1d4ed8}

/* shared drawer helpers */
.d-label{font-size:11px;color:#6b7280;margin-bottom:4px}
.d-input{width:100%;border:0.5px solid #d1d5db;border-radius:5px;padding:7px 9px;font-size:13px;color:#111;outline:none;background:#fff}
.d-input:focus{border-color:#2563eb}
.d-input.readonly{background:#f9fafb;color:#6b7280}
.d-textarea{width:100%;border:0.5px solid #d1d5db;border-radius:5px;padding:7px 9px;font-size:13px;color:#111;outline:none;background:#fff;resize:vertical;min-height:60px}
.d-select{width:100%;border:0.5px solid #d1d5db;border-radius:5px;padding:7px 9px;font-size:13px;color:#374151;outline:none;background:#fff}
.d-checkbox-row{display:flex;align-items:center;gap:8px;font-size:13px;color:#374151;margin-bottom:8px}
.d-checkbox-row input{accent-color:#2563eb;width:14px;height:14px}
.section-title{font-size:13px;font-weight:600;color:#374151;margin-bottom:14px}
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.mb12{margin-bottom:12px}
.mb16{margin-bottom:16px}

/* sub-tab system inside drawer */
.sub-tabs{display:flex;gap:0;border-bottom:0.5px solid #e5e7eb;margin-bottom:16px}
.stab{padding:7px 14px;font-size:12px;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap}
.stab:hover{color:#374151}
.stab.active{color:#2563eb;border-bottom:2px solid #2563eb;font-weight:500}

/* access/noaccess subtabs */
.access-subtabs{display:flex;gap:0;margin-bottom:14px}
.atab{padding:6px 14px;font-size:13px;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;display:flex;align-items:center;gap:6px}
.atab.active{color:#2563eb;border-bottom:2px solid #2563eb;font-weight:500}
.atab-badge{background:#2563eb;color:#fff;border-radius:10px;padding:1px 7px;font-size:11px;font-weight:600}
.atab-badge-gray{background:#e5e7eb;color:#374151;border-radius:10px;padding:1px 7px;font-size:11px;font-weight:600}

/* generic table inside drawer */
.d-table{width:100%;border-collapse:collapse;font-size:13px}
.d-table th{padding:8px 10px;text-align:left;color:#6b7280;font-weight:500;font-size:12px;border-bottom:0.5px solid #e5e7eb}
.d-table td{padding:9px 10px;color:#374151;border-bottom:0.5px solid #f3f4f6}
.d-table tr:last-child td{border-bottom:none}

/* access badges */
.ab{display:inline-block;border-radius:4px;padding:2px 8px;font-size:11px;font-weight:500}
.ab-access{background:#d1fae5;color:#065f46}
.ab-rw{background:#fef3c7;color:#92400e}
.ab-read{background:#dbeafe;color:#1d4ed8}
.ab-noaccess{background:#fee2e2;color:#991b1b}
.default-badge{background:#ef4444;color:#fff;border-radius:4px;padding:2px 7px;font-size:11px;font-weight:600;margin-left:6px}

/* dual list */
.dual-wrap{display:grid;grid-template-columns:1fr 52px 1fr;gap:0;align-items:start}
.dual-col-hdr{font-size:13px;font-weight:600;color:#374151;margin-bottom:8px}
.dual-sr{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.dual-s{flex:1;border:0.5px solid #d1d5db;border-radius:5px;padding:5px 8px;font-size:12px;outline:none;color:#111}
.dual-s:focus{border-color:#2563eb}
.dual-list{border:0.5px solid #d1d5db;border-radius:5px;overflow-y:auto;max-height:260px;background:#fff}
.dl-hdr{display:flex;align-items:center;gap:8px;padding:6px 10px;border-bottom:0.5px solid #e5e7eb;font-size:12px;font-weight:600;background:#fafafa}
.dl-item{display:flex;align-items:center;gap:8px;padding:6px 10px;border-bottom:0.5px solid #f3f4f6;font-size:12px;color:#374151}
.dl-item:last-child{border-bottom:none}
.dl-item:hover{background:#f9fafb}
.dual-arrows{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:0 4px;margin-top:56px}
.darr{border:0.5px solid #d1d5db;border-radius:4px;padding:4px 8px;font-size:11px;background:#fff;cursor:pointer;color:#374151;white-space:nowrap}
.darr:hover{background:#f3f4f6}

/* toggle switch */
.toggle{position:relative;display:inline-block;width:36px;height:20px}
.toggle input{opacity:0;width:0;height:0}
.toggle-slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#d1d5db;border-radius:20px;transition:.2s}
.toggle-slider:before{position:absolute;content:"";height:14px;width:14px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s}
.toggle input:checked+.toggle-slider{background:#16a34a}
.toggle input:checked+.toggle-slider:before{transform:translateX(16px)}

/* tag chip */
.tag-chip{display:inline-flex;align-items:center;gap:4px;background:#eff6ff;color:#1d4ed8;border-radius:4px;padding:3px 8px;font-size:12px;font-weight:500}
.tag-chip button{background:none;border:none;cursor:pointer;color:#6b7280;font-size:13px;line-height:1;padding:0}

/* section header bar */
.section-bar{padding:8px 12px;border-radius:6px;font-size:12px;font-weight:600;color:#fff;margin-bottom:10px;cursor:pointer}
.bar-green{background:#16a34a}
.bar-amber{background:#d97706}
.bar-blue{background:#2563eb}

/* info banner */
.info-banner{background:#eff6ff;border:0.5px solid #bfdbfe;border-radius:6px;padding:8px 12px;font-size:12px;color:#1e40af;margin-bottom:14px}

/* row actions */
.btn-sm{border:0.5px solid #d1d5db;border-radius:4px;padding:4px 10px;font-size:12px;background:#fff;cursor:pointer;color:#374151}
.btn-sm:hover{background:#f3f4f6}
.btn-sm-blue{border:none;border-radius:4px;padding:4px 10px;font-size:12px;background:#2563eb;cursor:pointer;color:#fff}
.btn-sm-blue:hover{background:#1d4ed8}
.btn-icon-red{background:none;border:none;cursor:pointer;color:#dc2626;font-size:14px;padding:4px}
.btn-icon-red:hover{color:#b91c1c}
.ctx-item{padding:9px 16px;font-size:13px;color:#374151;cursor:pointer}
.ctx-item:hover{background:#f3f4f6}
</style>
</head>
<body>

<!-- TOP NAV -->
<div class="topnav">
  <div class="logo">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><polygon points="12,2 22,7 22,17 12,22 2,17 2,7" fill="#4a7fcb" stroke="#6a9de0" stroke-width="1"/><text x="12" y="16" text-anchor="middle" font-size="9" fill="#fff" font-weight="bold">V8</text></svg>
    Voyager 8
  </div>
  <div class="nav-item">Home</div>
  <div class="nav-item">Setup <span class="nav-arrow">▾</span></div>
  <div class="nav-item">Admin <span class="nav-arrow">▾</span></div>
  <div class="nav-item">System <span class="nav-arrow">▾</span></div>
  <div class="nav-item active">Security <span class="nav-arrow">▾</span></div>
  <div class="nav-item">Toolbox <span class="nav-arrow">▾</span></div>
  <div class="nav-item">Reports <span class="nav-arrow">▾</span></div>
  <div class="nav-item">Interfaces <span class="nav-arrow">▾</span></div>
  <div class="topnav-right">
    <span class="topnav-icon">☆</span>
    <span class="topnav-icon">?</span>
    <div class="avatar">AB</div>
  </div>
</div>

<div style="display:flex">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></div>
    <div class="sidebar-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div>
    <div class="sidebar-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
    <div class="sidebar-icon active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 9-7 10C8.5 21 5 17 5 12V6l7-4z"/></svg></div>
    <div style="margin-top:auto" class="sidebar-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
  </div>

  <div class="main" style="flex:1">
    <div class="page-header">
      <div class="header-row">
        <div class="shield-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 9-7 10C8.5 21 5 17 5 12V6l7-4z"/></svg>
        </div>
        <div>
          <div class="page-title">Security Hub</div>
          <div class="page-sub">Manage security groups and user access</div>
        </div>
      </div>
      <div class="tabs">
        <div class="tab" onclick="showTab('groups',this)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 9-7 10C8.5 21 5 17 5 12V6l7-4z"/></svg>
          Security Groups
        </div>
        <div class="tab active" onclick="showTab('users',this)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Users
        </div>
        <div class="tab" onclick="showTab('roles',this)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
          Roles
        </div>
        <div class="tab" onclick="showTab('reports',this)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Reports
        </div>
      </div>
    </div>

    <div class="content">
      <!-- SECURITY GROUPS -->
      <div id="tab-groups" style="display:none">
        <div class="toolbar">
          <div class="search-wrap"><span class="search-icon">&#128269;</span><input type="text" placeholder="Search" oninput="filterTable('groups-tbody',this.value,[0,1])"></div>
          <span class="count-badge">244</span><span class="toolbar-label">Groups</span>
          <div class="ml-auto" style="display:flex;gap:8px"><button class="btn-primary">+ Add Group</button><button class="btn-more">⋮</button></div>
        </div>
        <div class="table-wrap">
          <table><thead><tr>
            <th style="width:32px"><input type="checkbox" class="cb"></th>
            <th>Group <span class="sort-icon">⇅</span></th><th>Description <span class="sort-icon">⇅</span></th>
            <th>Users <span class="sort-icon">⇅</span></th><th>Accounts <span class="sort-icon">⇅</span></th>
            <th>Charge Codes <span class="sort-icon">⇅</span></th><th>Acct Trees <span class="sort-icon">⇅</span></th><th>Books <span class="sort-icon">⇅</span></th>
          </tr></thead><tbody id="groups-tbody"></tbody></table>
        </div>
      </div>

      <!-- USERS -->
      <div id="tab-users">
        <div class="toolbar">
          <div class="search-wrap"><span class="search-icon">&#128269;</span><input type="text" placeholder="Search" oninput="filterTable('users-tbody',this.value,[0,1,2])"></div>
          <span class="count-badge">10</span><span class="toolbar-label">Users</span>
          <div class="ml-auto" style="display:flex;gap:8px;position:relative">
            <button class="btn-primary">+ Add User</button>
            <button class="btn-more" onclick="toggleUserMenu(event)">⋮</button>
            <div id="userContextMenu" style="display:none;position:absolute;top:36px;right:0;background:#fff;border:0.5px solid #e0e0e0;border-radius:7px;box-shadow:0 4px 12px rgba(0,0,0,.1);min-width:160px;z-index:50;overflow:hidden">
              <div class="ctx-item">Export to CSV</div>
              <div class="ctx-item">Update from CSV</div>
              <div class="ctx-item">Bulk Edit</div>
              <div class="ctx-item">Refresh Data</div>
            </div>
          </div>
        </div>
        <div class="table-wrap">
          <table><thead><tr>
            <th style="width:32px"><input type="checkbox" class="cb"></th>
            <th>Login <span class="sort-icon">⇅</span></th><th>Name <span class="sort-icon">⇅</span></th>
            <th>Email <span class="sort-icon">⇅</span></th><th>Groups <span class="sort-icon">⇅</span></th>
            <th>Status <span class="sort-icon">⇅</span></th><th>Last Login <span class="sort-icon">⇅</span></th>
          </tr></thead><tbody id="users-tbody"></tbody></table>
        </div>
      </div>

      <!-- ROLES -->
      <div id="tab-roles" style="display:none">
        <div class="toolbar">
          <div class="search-wrap"><span class="search-icon">&#128269;</span><input type="text" placeholder="Search" oninput="filterTable('roles-tbody',this.value,[0,1,2])"></div>
          <span class="count-badge">8</span><span class="toolbar-label">Roles</span>
          <div class="ml-auto" style="display:flex;gap:8px"><button class="btn-primary">+ Add Role</button><button class="btn-more">⋮</button></div>
        </div>
        <div class="table-wrap">
          <table><thead><tr>
